{
  "name": "app",
  "private": true,
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "esbuild": "^0.28.0"
  },
  "dependencies": {
    "@hotwired/turbo-rails": "^8.0.23",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "postcss-import": "^16.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-modal": "^3.16.3",
    "react-router-dom": "^6.22.0",
    "react-toastify": "^11.1.0",
    "tailwindcss": "^4.3.0"
  },
  "scripts": {
    "build": "esbuild app/javascript/*.* --bundle --sourcemap --format=esm --outdir=app/assets/builds --public-path=/assets",
    "build:watch": "esbuild app/javascript/*.* --bundle --sourcemap --format=esm --outdir=app/assets/builds --public-path=/assets --watch",
    "build:css": "tailwindcss -i ./app/assets/stylesheets/application.css -o ./app/assets/builds/application.css",
    "build:css:watch": "tailwindcss -i ./app/assets/stylesheets/application.css -o ./app/assets/builds/application.css --watch"
  }
}
